# PostgreSQL connection (relational data: FAQs + chat logs)
DATABASE_URL=postgresql+psycopg://uniclubs:uniclubs@localhost:5432/uniclubs

# Google Gemini (chat + embeddings)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_CHAT_TEMPERATURE=0.3
GEMINI_EMBED_MODEL=gemini-embedding-001

# Vector database (ChromaDB, persistent on disk)
CHROMA_PATH=./chroma_data
CHROMA_COLLECTION=faqs

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# Security — RS256: tokens are validated against the IdentityProvider public key.
# IDP_JWKS_URL must point to the running IdentityProvider /.well-known/jwks endpoint.
IDP_JWKS_URL=http://localhost:8080/.well-known/jwks
JWT_ISSUER=IdentityProvider
JWT_AUDIENCE=myappusers
